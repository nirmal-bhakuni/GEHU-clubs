NODE_ENV=production
PORT=12346
HOST=0.0.0.0

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
SESSION_SECRET=replace-with-a-long-random-secret

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=https://your-frontend-domain.com

# Optional controls
DISABLE_AUTO_SEED=true
EVENT_REMINDER_DAYS=3
EVENT_REMINDER_INTERVAL_HOURS=6
EMAIL_BATCH_SIZE=50
DISABLE_EMAIL_NOTIFICATIONS=false

# Optional SMTP (choose either SMTP_URL or host/port/user/pass)
# SMTP_URL=smtp://USER:PASS@HOST:PORT
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_SECURE=false
# SMTP_FROM=GEHU Clubs <noreply@gehu.ac.in>

# Teacher ERP Sync (optional, enables direct push to main ERP)
# ERP_SYNC_URL=https://your-main-erp.example.com/api/attendance/sync
# ERP_SYNC_TOKEN=replace-with-erp-api-token
